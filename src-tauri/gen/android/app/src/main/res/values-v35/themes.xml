<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.slate" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Android 15 still allows opting out; padding in MainActivity is the real fix. -->
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
        <item name="android:statusBarColor">@color/surface_0</item>
        <item name="android:navigationBarColor">@color/surface_0</item>
        <item name="android:enforceStatusBarContrast">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>
    </style>
</resources>