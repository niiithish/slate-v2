{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Slate",
  "version": "0.1.0",
  "identifier": "com.nithish.slate",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Slate",
        "width": 360,
        "height": 620,
        "minWidth": 320,
        "minHeight": 520,
        "maxWidth": 420,
        "maxHeight": 680,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "android": {
      "minSdkVersion": 24
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
