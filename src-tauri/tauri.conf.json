{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Slate",
  "version": "0.1.0",
  "identifier": "com.nithish.slate",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Slate",
        "width": 360,
        "height": 620,
        "center": true,
        "resizable": false,
        "fullscreen": false,
        "maximized": false,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMwNkI4N0M4NjU3NzMwMjUKUldRbE1IZGx5SWRyTU83WjE5WC9kaXdPM1RoQnFHTWpzWjZzVGREbndrMzhrQmRONzVNWURkNzEK",
      "endpoints": [
        "https://github.com/niiithish/slate-v2/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["deb", "rpm", "appimage"],
    "android": {
      "minSdkVersion": 24
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
